[resource]
code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, cull_back, diffuse_lambert, specular_schlick_ggx;

instance uniform vec4 ColorParameter : source_color = vec4(0.976471, 0.905882, 0.705882, 1.000000);
uniform sampler2D tex_frg_3;



void fragment() {
// ColorParameter:2
	vec4 n_out2p0 = ColorParameter;


// Texture2D:3
	vec4 n_out3p0 = texture(tex_frg_3, UV);


// VectorOp:4
	vec3 n_in4p1 = vec3(0.50000, 1.00000, 0.00000);
	vec3 n_out4p0 = vec3(n_out3p0.xyz) * n_in4p1;


// FloatOp:11
	float n_in11p1 = 1.25000;
	float n_out11p0 = pow(n_out4p0.x, n_in11p1);


// VectorOp:10
	vec3 n_out10p0 = vec3(n_out2p0.xyz) + vec3(n_out11p0);


// Output:0
	ALBEDO = n_out10p0;


}
"
