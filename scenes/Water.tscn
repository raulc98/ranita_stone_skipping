code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, cull_back, diffuse_lambert, specular_toon;

uniform sampler2D tex_vtx_2;
uniform vec4 ColorParameter : source_color = vec4(0.352941, 0.713726, 1.000000, 1.000000);
uniform sampler2D tex_frg_3;
uniform sampler2D tex_frg_7;
uniform sampler2D depth_tex_frg_14 : hint_depth_texture;



void vertex() {
// UVFunc:6
	vec2 n_in6p1 = vec2(0.10000, 0.10000);
	vec2 n_in6p2 = vec2(0.00000, 0.00000);
	vec2 n_out6p0 = n_in6p2 * n_in6p1 + UV;


// Texture2D:2
	vec4 n_out2p0 = texture(tex_vtx_2, n_out6p0);


// VectorOp:8
	vec3 n_in8p0 = vec3(0.00000, 0.00000, 0.00000);
	vec3 n_in8p1 = vec3(0.20000, 0.20000, 0.20000);
	vec3 n_out8p0 = n_in8p0 * n_in8p1;


// MultiplyAdd:5
	vec3 n_in5p2 = vec3(0.00000, 0.00000, 0.00000);
	vec3 n_out5p0 = (vec3(n_out2p0.xyz) * n_out8p0) + n_in5p2;


// Output:0
	VERTEX = n_out5p0;


}

void fragment() {
// ColorParameter:2
	vec4 n_out2p0 = ColorParameter;


// Input:6
	float n_out6p0 = TIME;


// UVFunc:5
	vec2 n_in5p1 = vec2(0.04000, 0.04000);
	vec2 n_in5p2 = vec2(1.00000, 0.00000);
	vec2 n_out5p0 = n_in5p2 * n_in5p1 + vec2(n_out6p0);


// Texture2D:3
	vec4 n_out3p0 = texture(tex_frg_3, n_out5p0);


// Input:8
	float n_out8p0 = TIME;


// UVFunc:9
	vec2 n_in9p1 = vec2(-0.04000, -0.04000);
	vec2 n_in9p2 = vec2(0.00000, 0.00000);
	vec2 n_out9p0 = n_in9p2 * n_in9p1 + vec2(n_out8p0);


// Texture2D:7
	vec4 n_out7p0 = texture(tex_frg_7, n_out9p0);


// VectorOp:4
	vec3 n_out4p0 = vec3(n_out3p0.xyz) * vec3(n_out7p0.xyz);


// FloatOp:11
	float n_in11p1 = 2.00000;
	float n_out11p0 = pow(n_out4p0.x, n_in11p1);


// VectorOp:10
	vec3 n_out10p0 = vec3(n_out2p0.xyz) + vec3(n_out11p0);


// Input:18
	float n_out18p0 = TIME;


	float n_out14p0;
// ProximityFade:14
	float n_in14p0 = 5.00000;
	{
		float __depth_tex = texture(depth_tex_frg_14, SCREEN_UV).r;
		vec4 __depth_world_pos = INV_PROJECTION_MATRIX * vec4(vec3(SCREEN_UV, __depth_tex) * 2.0 - 1.0, 1.0);
		__depth_world_pos.xyz /= __depth_world_pos.w;
		n_out14p0 = clamp(1.0 - smoothstep(__depth_world_pos.z + n_in14p0, __depth_world_pos.z, VERTEX.z), 0.0, 1.0);
	}


// FloatFunc:15
	float n_out15p0 = 1.0 - n_out14p0;


// MultiplyAdd:25
	vec3 n_in25p1 = vec3(2.00000, 2.00000, 2.00000);
	vec3 n_out25p0 = (vec3(n_out18p0) * n_in25p1) + vec3(n_out15p0);


// FloatOp:24
	float n_in24p1 = 2.00000;
	float n_out24p0 = n_out25p0.x * n_in24p1;


// FloatFunc:17
	float n_out17p0 = sin(n_out24p0);


// FloatFunc:20
	float n_out20p0 = abs(n_out17p0);


// FloatOp:22
	float n_in22p1 = 1.00000;
	float n_out22p0 = pow(n_out15p0, n_in22p1);


// FloatOp:21
	float n_out21p0 = n_out20p0 * n_out22p0;


// FloatOp:23
	float n_out23p0 = n_out21p0 + n_out22p0;


// Mix:26
	vec3 n_in26p1 = vec3(1.00000, 1.00000, 1.00000);
	vec3 n_out26p0 = mix(n_out10p0, n_in26p1, vec3(n_out23p0));


// FloatConstant:12
	float n_out12p0 = 0.950000;


// Output:0
	ALBEDO = n_out26p0;
	ALPHA = n_out12p0;
	ROUGHNESS = n_out12p0;
	EMISSION = vec3(n_out11p0);


}
"
